{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' cdn.jsdelivr.net unpkg.com fonts.googleapis.com cdnjs.cloudflare.com 'unsafe-inline'; style-src 'self' fonts.googleapis.com fonts.gstatic.com unpkg.com 'unsafe-inline'; img-src * data: blob:; connect-src *.supabase.co;" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/negocios",              "destination": "/negocios.html" },
    { "source": "/business",              "destination": "/business/index.html" },
    { "source": "/business/registro",     "destination": "/business/registro.html" },
    { "source": "/business/login",        "destination": "/business/login.html" },
    { "source": "/business/verificacion", "destination": "/business/verificacion.html" },
    { "source": "/business/dashboard",    "destination": "/business/dashboard.html" },
    { "source": "/business/perfil",       "destination": "/business/perfil.html" },
    { "source": "/business/reviews",      "destination": "/business/reviews.html" },
    { "source": "/business/analytics",    "destination": "/business/analytics.html" },
    { "source": "/business/planes",       "destination": "/business/planes.html" },
    { "source": "/admin",                  "destination": "/admin.html" },
    { "source": "/business/admin",        "destination": "/business/admin.html" },
    { "source": "/reset-password",        "destination": "/reset-password.html" },
    { "source": "/privacy",               "destination": "/privacy.html" },
    { "source": "/terms",                 "destination": "/terms.html" }
  ]
}
